{
  "name": "guardrails-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Unified management console for the guardrails and extproc-guardrails services",
  "scripts": {
    "gen": "openapi-typescript spec/openapi.yaml -o src/api/schema.d.ts",
    "dev": "vite",
    "prebuild": "npm run gen",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@snack-uikit/alert": "^0.16.32",
    "@snack-uikit/button": "^0.19.19",
    "@snack-uikit/button-combo": "^0.2.40",
    "@snack-uikit/card": "^0.20.23",
    "@snack-uikit/chips": "^0.30.2",
    "@snack-uikit/divider": "^3.2.12",
    "@snack-uikit/drawer": "^0.14.3",
    "@snack-uikit/fields": "^0.57.2",
    "@snack-uikit/figma-tokens": "^19.0.5",
    "@snack-uikit/icons": "^0.27.7",
    "@snack-uikit/list": "^0.33.3",
    "@snack-uikit/loaders": "^0.9.11",
    "@snack-uikit/modal": "^0.20.2",
    "@snack-uikit/segmented-control": "^0.6.23",
    "@snack-uikit/skeleton": "^0.6.11",
    "@snack-uikit/status": "^0.10.15",
    "@snack-uikit/table": "^0.39.5",
    "@snack-uikit/toaster": "^0.11.30",
    "@snack-uikit/toggles": "^0.13.27",
    "@snack-uikit/typography": "^0.8.13",
    "@snack-uikit/utils": "^4.0.2",
    "@tanstack/react-query": "^5.62.0",
    "classnames": "^2.5.1",
    "openapi-fetch": "^0.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.15.0",
    "openapi-typescript": "^7.4.4",
    "prettier": "^3.4.2",
    "sass": "^1.83.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0"
  }
}
